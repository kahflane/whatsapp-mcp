{
  "name": "@kahflane/whatsapp-mcp",
  "version": "0.1.0",
  "description": "WhatsApp MCP server built on the innovatorssoft Baileys fork + the Anthropic Model Context Protocol SDK. Runs on Bun.",
  "type": "module",
  "module": "src/index.ts",
  "license": "MIT",
  "author": "kahflane",
  "homepage": "https://github.com/kahflane/whatsapp-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kahflane/whatsapp-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/kahflane/whatsapp-mcp/issues"
  },
  "keywords": [
    "whatsapp",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "baileys",
    "ai-agents",
    "claude",
    "claude-code",
    "codex",
    "cursor",
    "opencode",
    "bun"
  ],
  "bin": {
    "whatsapp-mcp": "src/index.ts"
  },
  "files": [
