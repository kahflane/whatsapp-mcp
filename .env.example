# ---- Login ----
# Leave empty to log in with a QR code (use the wa_get_login_qr tool).
# Set to an E.164 number WITHOUT + / spaces / dashes (e.g. 8801XXXXXXXXX) to
# log in with an 8-digit pairing code instead (use wa_get_pairing_code).
WA_PAIRING_NUMBER=

# ---- History ----
# true = emulate a desktop client and pull full chat history on first login.
WA_SYNC_FULL_HISTORY=true

# ---- Anti-ban pacing ----
WA_MIN_GAP_MS=2000          # min delay between outbound sends
WA_MAX_GAP_MS=5000          # max delay between outbound sends
WA_DAILY_CAP=100            # refuse to send more than this many messages/day

# ---- Paths ----
# Leave these UNSET to store everything under ~/.whatsapp-mcp/ (recommended —
# one login + history regardless of which folder the server starts from).
# Set WA_DATA_DIR to relocate the whole lot; auth/db/media default under it.
# Uncomment to keep data inside the project instead (handy for local dev):
# WA_DATA_DIR=./data
# WA_AUTH_DIR=./data/auth
# WA_DB_PATH=./data/whatsapp.db
# WA_MEDIA_DIR=./data/media

# ---- Logging (to stderr only) ----
WA_LOG_LEVEL=warn           # trace | debug | info | warn | error | fatal
